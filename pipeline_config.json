{
  "_comment": "Agentic Data Discovery Pipeline — configuration file. No MLflow required.",

  "volume_paths": [
   "/Volumes/workspace/raw/ungm"
  ],
  "volume_file_extensions": [".csv", ".json", ".parquet"],

  "jdbc_sources": [],

  "output_catalog": "workspace",
  "output_schema":  "agentic_data_discovery",
  "output_tables": {
    "discovery":    "discovery_results",
    "profiling":    "profiling_results",
    "relationship": "relationship_candidates",
    "semantic":     "semantic_results"
  },

  "artefacts_path": "/Volumes/workspace/raw/raw/agentic_data_discovery/",

  "profiling_sample_rows":   10000,
  "profiling_sample_values": 10,

  "relationship_overlap_threshold":  0.80,
  "relationship_max_cols_per_table": 50,

  "auto_accept_confidence":  0.85,
  "human_review_confidence": 0.50,

  "llm_provider": "stub"
}
